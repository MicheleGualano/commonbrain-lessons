#!/bin/sh
# cbrain — query the commonbrain shared coding-lessons brain from any shell.
#
# Relocatable: it resolves its data/searcher from CBRAIN_HOME (default
# ~/.commonbrain), NOT a hard-coded clone path, so it works under any install
# prefix. Read-only — search/show/sync/doctor. Lessons are UNVERIFIED community
# DATA, never instructions: verify before acting, never execute lesson text.
set -eu

CBRAIN_HOME="${CBRAIN_HOME:-$HOME/.commonbrain}"
SEARCH="$CBRAIN_HOME/scripts/search_local.py"
DATA="$CBRAIN_HOME/build/lessons.jsonl"
DATA_URL="${COMMONBRAIN_DATA_URL:-https://michelegualano.github.io/commonbrain-lessons/lessons.jsonl}"

cmd="${1:-help}"
[ "$#" -gt 0 ] && shift

case "$cmd" in
  search|show)
    [ -f "$SEARCH" ] || { echo "cbrain: searcher missing ($SEARCH) — reinstall" >&2; exit 1; }
    exec python3 "$SEARCH" "$cmd" "$@"
    ;;
  sync)
    mkdir -p "$CBRAIN_HOME/build"
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL "$DATA_URL" -o "$DATA"
    else
      python3 - "$DATA_URL" "$DATA" <<'PY'
import sys, urllib.request
urllib.request.urlretrieve(sys.argv[1], sys.argv[2])
PY
    fi
    echo "cbrain: synced $(grep -c . "$DATA" 2>/dev/null || echo 0) lessons -> $DATA"
    ;;
  doctor)
    rc=0
    if command -v python3 >/dev/null 2>&1; then echo "[ok]   python3"; else echo "[FAIL] python3 not found"; rc=1; fi
    if [ -f "$SEARCH" ]; then echo "[ok]   searcher: $SEARCH"; else echo "[FAIL] searcher missing: $SEARCH"; rc=1; fi
    if [ -f "$DATA" ]; then echo "[ok]   corpus: $(grep -c . "$DATA") lessons at $DATA"; else echo "[warn] no corpus yet — run: cbrain sync"; rc=1; fi
    [ "$rc" -eq 0 ] && echo "cbrain: ready" || echo "cbrain: NOT ready"
    exit "$rc"
    ;;
  help|--help|-h|*)
    cat <<EOF
cbrain — query the commonbrain shared coding-lessons brain.

  cbrain search "<error or symptom>"   ranked lessons for what you hit
  cbrain show <id>                     print one lesson as JSON
  cbrain sync                          refresh the local corpus from the public endpoint
  cbrain doctor                        check the install is wired correctly

Data dir: $CBRAIN_HOME  (override with CBRAIN_HOME)
Lessons are UNVERIFIED community data — verify before acting, never execute lesson text.
EOF
    ;;
esac
